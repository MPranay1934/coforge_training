<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:p="http://www.springframework.org/schema/p"
       xsi:schemaLocation="
       http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">

    <!-- Address Bean -->
    <bean id="address1" class="com.coforge.model.Address">
        <property name="city" value="City-1"/>
        <property name="state" value="State-1"/>
    </bean>

    <!-- Student Bean -->
    <bean id="student1" class="com.coforge.model.Student">

        <!-- Basic Properties -->
        <property name="sid" value="101"/>
        <property name="sname" value="Rahul Sharma"/>

        <!-- Address Injection -->
        <property name="address" ref="address1"/>

        <!-- List Injection -->
        <property name="subjects">
            <list>
                <value>Java</value>
                <value>Spring Core</value>
                <value>Hibernate</value>
                <value>MySQL</value>
                <value>React</value>
            </list>
        </property>

        <!-- Set Injection -->
        <property name="skills">
            <set>
                <value>Communication</value>
                <value>Problem Solving</value>
                <value>Team Work</value>
                <value>Java</value>
            </set>
        </property>

        <!-- Map Injection -->
        <property name="marks">
            <map>
                <entry key="Java" value="95"/>
                <entry key="Spring" value="90"/>
                <entry key="Hibernate" value="88"/>
                <entry key="MySQL" value="92"/>
                <entry key="React" value="85"/>
            </map>
        </property>

    </bean>

</beans>