<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:p="http://www.springframework.org/schema/p"
	xsi:schemaLocation="http://www.springframework.org/schema/beans
http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">
	<bean id="customer1" class="com.coforge.model.Customer">
		<property name="customerid" value="101"></property>
		<property name="customername" value="Pranay"></property>
		<property name="emails">
			<list>
				<value>spu@gmail.com</value>
				<value>mtu@gmail.com</value>
			</list>
		</property>
		<property name="deliveryaddress">
			<list>
				<ref bean="deliveryaddress1" />
				<ref bean="deliveryaddress2"/>
			</list>
		</property>

	</bean>
	<bean id="deliveryaddress1"
		class="com.coforge.model.DeliveryAddress">
		<property name="city" value="city-1"></property>
		<property name="state" value="state-1"></property>
	</bean>
	<bean id="deliveryaddress2"
		class="com.coforge.model.DeliveryAddress">
		<property name="city" value="city-2"></property>
		<property name="state" value="state-2"></property>
	</bean>
</beans>